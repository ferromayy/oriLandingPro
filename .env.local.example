# URL pública del sitio (opcional). Si no está definida, el QR usa el dominio actual.
# NEXT_PUBLIC_SITE_URL=https://www.oricafe.com.ar

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Alias antiguo (opcional): NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Obligatorio para el panel admin (CRUD + subida de imágenes).
# Supabase → Project Settings → API → secret key (sb_secret_...)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
# Alias equivalente: SUPABASE_SECRET_KEY=sb_secret_...

# Superadmin (solo servidor — no uses NEXT_PUBLIC_)
SUPERADMIN_EMAIL=superadmin@ori.local
SUPERADMIN_PASSWORD=cambia-esta-contraseña-segura
# Mínimo 32 caracteres. Genera una aleatoria: openssl rand -base64 32
SUPERADMIN_SESSION_SECRET=reemplaza-con-un-secreto-largo-y-aleatorio-min-32-chars
